# Copy this file to `.env` for local testing.
# Never commit real tokens to git.

# GitHub token used by electron-updater for private GitHub releases.
# Use a fine-grained PAT with read access to the Mehinachicken repo.
GH_TOKEN=

# Optional alias supported by some tools; GH_TOKEN takes precedence.
# GITHUB_TOKEN=ghp_replace_with_your_token
