{
  "name": "mehinachicken",
  "version": "1.0.0",
  "description": "Electron wrapper for the Mehinachicken web app",
  "main": "electron-main.js",
  "private": true,
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3",
    "@electron/rebuild": "^3.6.0"
  },
  "overrides": {
    "node-gyp": "^10.2.0"
  },
  "build": {
    "appId": "com.mehinachicken.app",
    "productName": "Mehinachicken",
    "files": [
      "index.html",
      "assets/**/*",
      "electron-main.js",
      "preload.js",
      "database.js",
      "app-config.js",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dodorob",
        "repo": "Mehinachicken",
        "private": true
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "dotenv": "^16.4.5",
    "better-sqlite3": "^11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dodorob/Mehinachicken.git"
  }
}
