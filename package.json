{
  "name": "mehinachicken",
  "version": "1.0.0",
  "description": "Electron wrapper for the Mehinachicken web app",
  "main": "electron-main.js",
  "private": true,
  "scripts": {
    "build:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mehinachicken.app",
    "productName": "Mehinachicken",
    "files": [
      "index.html",
      "assets/**/*",
      "electron-main.js",
      "preload.js"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dodorob",
        "repo": "Mehinachicken",
        "private": true
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "dotenv": "^16.4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dodorob/Mehinachicken.git"
  }
}